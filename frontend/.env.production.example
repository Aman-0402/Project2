# ==========================================
# LUXE PARFUM — Frontend Production Variables
# Set these in Vercel dashboard (Project > Settings > Environment Variables)
# ==========================================

# Backend API URL (your Render/VPS backend, no trailing slash)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api

# WhatsApp number in international format (+country code)
NEXT_PUBLIC_WHATSAPP_NUMBER=+1234567890

# Brand display name
NEXT_PUBLIC_BRAND_NAME=LUXE PARFUM

# Your production frontend domain (used for sitemap + OG tags)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
