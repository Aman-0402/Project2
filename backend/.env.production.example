# ==========================================
# LUXE PARFUM — Production Environment Variables
# Copy to .env on your server/Render dashboard
# ==========================================

# Django (REQUIRED)
SECRET_KEY=generate-a-50-char-random-string-here
DEBUG=False
ALLOWED_HOSTS=your-backend-domain.onrender.com,api.yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# Database — MySQL (REQUIRED)
DB_NAME=luxe_parfum
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_HOST=your-db-host.region.aws.com
DB_PORT=3306

# Cloudinary (REQUIRED for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# JWT lifetimes
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# Frontend URL (used in sitemaps, emails, etc.)
FRONTEND_URL=https://yourdomain.com
